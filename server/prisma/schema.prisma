// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  name            String
  emailVerified   Boolean  @default(false)
  balanceUSD      Decimal  @default(0) @db.Decimal(18, 6) // для удобства, чтобы не дергать конвертацию при каждом списании
  balance         Decimal  @default(0) @db.Decimal(18, 8) // 8 знаков после запятой для центов
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  amountOfQueries Int      @default(0)
  systemPrompt    String   @default("")

  chats                   Chat[]
  transactions            Transaction[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]
  payments                Payment[]
}

model Chat {
  id           String    @id @default(cuid())
  userId       String
  title        String    @default("New Chat")
  systemPrompt String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? // soft delete

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, deletedAt]) // для быстрой выборки активных чатов
}

model Message {
  id             String   @id @default(cuid())
  chatId         String
  role           String // "user" | "assistant" | "system"
  content        String
  model          String? // "anthropic/claude-3.5-sonnet" — только для assistant
  modelName      String? // "Claude 3.5 Sonnet" — для удобства, можно не сохранять и дергать по модели
  inputTokens    Int?
  outputTokens   Int?
  cost           Decimal? @db.Decimal(10, 6)
  rubPrice       Decimal? @default(0) @db.Decimal(10, 2) // цена в рублях, для удобства, чтобы не дергать конвертацию при каждом сообщении
  createdAt      DateTime @default(now())
  hasAttachments Boolean  @default(false)
  order          Int
  inContext      Boolean  @default(true)

  chat         Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  attachments  Attachment[]

  @@index([chatId, order])
}

model Attachment {
  id            String  @id @default(cuid())
  messageId     String
  name          String
  mimeType      String
  data          String  @db.Text // base64 или текст — нужен Text, не String
  isImage       Boolean
  size          Int
  extractedText String?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String // "topup" | "usage" | "refund" | "bonus"
  amount      Decimal  @db.Decimal(10, 6) // отрицательное для списаний
  description String
  messageId   String? // связь с сообщением, если это usage
  createdAt   DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model PromoCode {
  id        String   @id @default(cuid())
  code      String   @unique
  maxUses   Int
  usedCount Int      @default(0)
  bonus     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  yookassaId  String   @unique
  amountRub   Decimal  @db.Decimal(10, 2)
  status      String   @default("pending") // pending | succeeded | canceled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([yookassaId])
  @@index([userId])
}
